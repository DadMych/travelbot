# Neon / Supabase / Vercel Postgres connection string
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Telegram bot from @BotFather
TELEGRAM_BOT_TOKEN=
# Your Telegram user ID (only you can add places)
TELEGRAM_OWNER_ID=

# Webhook URL after deploy: https://your-app.vercel.app/api/telegram/webhook
# Set via: curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=<URL>"

# Site access (simple password for your personal map)
SITE_PASSWORD=

# Optional: secret for API auth
API_SECRET=
